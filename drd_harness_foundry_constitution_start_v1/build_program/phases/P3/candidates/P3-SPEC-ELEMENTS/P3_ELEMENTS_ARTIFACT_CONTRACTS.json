  "coverage_rule": "Every eligible closure node, clickable, reaction message, async message, failure recovery element, handoff surface, and terminal explanation must map to a canonical element row or to a blocked product expansion gap.",
  "deduction_rule": "DEDUCTIVE_PRIMARY is required for canonical missing elements; INDUCTIVE_AUXILIARY remains non-canonical until Human Gate approval.",
  "product_boundary_rule": "No element artifact may create a new product capability, data scope, integration, workflow, role, permission, page family, or business promise without a resolved product expansion gap decision.",
  "open_blockers": [],
  "canonical_projection_rule": {
    "included": [
      "prd_element_decisions.outcome in {ADOPT_AS_IS, ADOPT_NORMALIZED}",
      "derived_element_decisions.canonical_eligibility == ELIGIBLE and derivation_strategy == DEDUCTIVE_PRIMARY and blocked_by == []",
      "product_expansion_gaps.status == RESOLVED_APPROVED and decision_ref is non-null, with matching Human Gate approved element decision"
    ],
    "excluded": [
      "prd_element_decisions.outcome in {REQUEST_CLARIFICATION, REJECT_CONFLICT, ROUTE_PRODUCT_GAP}",
      "product_expansion_gaps.status in {OPEN, RESOLVED_REJECTED, SUPERSEDED}",
      "structural_completion_review rows before Human Gate approval",
      "derived_element_decisions.derivation_strategy == INDUCTIVE_AUXILIARY unless Human Gate approval creates a separate HUMAN_DECIDED inference",
      "any row with canonical_eligibility != ELIGIBLE or non-empty blocked_by"
    ],
    "join_keys": [
      "prd_element_inventory.element_id == prd_element_decisions.element_id",
      "derived_element_decisions.derived_element_id is the canonical element id for eligible derived rows",
      "input_obligations.obligation_id must be referenced by a decision, derived decision, or product gap when required",
      "product_expansion_gaps.gap_id must be referenced by blocked artifacts or gap-routed decisions"
    ],
    "downstream_rule": "P3-SPEC-PATTERNS, P3-SPEC-LAYOUT, and compiler work may consume only included projection ids or cite excluded ids as blocked evidence."
  }
