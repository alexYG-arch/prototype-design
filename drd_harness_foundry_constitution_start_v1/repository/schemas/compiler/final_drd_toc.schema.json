{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "items": {
    "additionalProperties": false,
    "properties": {
      "heading_text": {"minLength": 1, "type": "string"},
      "section_id": {"minLength": 1, "type": "string"},
      "section_order_index": {"type": "integer"},
      "source_hash": {"pattern": "^[a-f0-9]{64}$", "type": "string"},
      "source_path": {"minLength": 1, "type": "string"},
      "stage_id": {"minLength": 1, "type": "string"},
      "stage_order_index": {"type": "integer"},
      "toc_entry_id": {"minLength": 1, "type": "string"}
    },
    "required": [
      "toc_entry_id", "stage_id", "section_id", "stage_order_index",
      "section_order_index", "heading_text", "source_path", "source_hash"
    ],
    "type": "object"
  },
  "minItems": 1,
  "type": "array"
}
