{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "items": {
    "additionalProperties": false,
    "properties": {
      "approval_ref": {"minLength": 1, "type": "string"},
      "compiled_section_id": {"minLength": 1, "type": "string"},
      "lock_ref": {"type": ["string", "null"]},
      "reference_id": {"minLength": 1, "type": "string"},
      "source_hash": {"pattern": "^[a-f0-9]{64}$", "type": "string"},
      "source_path": {"minLength": 1, "type": "string"},
      "source_snapshot_identity": {"type": "object"},
      "source_stage_id": {"minLength": 1, "type": "string"},
      "validator_result_refs": {"items": {"type": "string"}, "type": "array"}
    },
    "required": [
      "reference_id", "compiled_section_id", "source_stage_id", "source_path",
      "source_hash", "approval_ref", "lock_ref", "validator_result_refs",
      "source_snapshot_identity"
    ],
    "type": "object"
  },
  "minItems": 1,
  "type": "array"
}
