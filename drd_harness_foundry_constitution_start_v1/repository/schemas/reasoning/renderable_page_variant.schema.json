{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "variant_page_id": {
      "minLength": 1,
      "type": "string"
    },
    "parent_page_id": {
      "minLength": 1,
      "type": "string"
    },
    "variant_kind": {
      "enum": [
        "BASE",
        "STATE_VARIANT"
      ]
    },
    "module_id": {
      "minLength": 1,
      "type": "string"
    },
    "module_order_index": {
      "minimum": 0,
      "type": "integer"
    },
    "function_group_id": {
      "minLength": 1,
      "type": "string"
    },
    "page_order_index": {
      "minimum": 0,
      "type": "integer"
    },
    "variant_order_index": {
      "minimum": 0,
      "type": "integer"
    },
    "figma_frame_order_index": {
      "minimum": 0,
      "type": "integer"
    },
    "derivation_origin": {
      "enum": [
        "PRD_EXPLICIT",
        "DEDUCTIVE_REQUIRED",
        "HUMAN_APPROVED_INFERENCE",
        "REVIEW_REQUIRED_INFERENCE"
      ]
    },
    "derivation_basis_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "source_state_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "render_surface_id": {
      "minLength": 1,
      "type": "string"
    },
    "state_condition": {
      "minLength": 1,
      "type": "string"
    },
    "shared_element_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "variant_element_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "source_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "trace_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "figma_frame_required": {
      "type": "boolean"
    },
    "product_capability_addition": {
      "const": false
    }
  },
  "required": [
    "variant_page_id",
    "parent_page_id",
    "variant_kind",
    "module_id",
    "module_order_index",
    "function_group_id",
    "page_order_index",
    "variant_order_index",
    "figma_frame_order_index",
    "derivation_origin",
    "derivation_basis_refs",
    "requires_human_review",
    "source_state_id",
    "render_surface_id",
    "state_condition",
    "shared_element_refs",
    "variant_element_refs",
    "source_refs",
    "trace_refs",
    "figma_frame_required",
    "product_capability_addition"
  ],
  "type": "object"
}
