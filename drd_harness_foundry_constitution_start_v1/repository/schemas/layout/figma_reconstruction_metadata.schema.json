{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "auto_layout_guidance": {
      "minLength": 1,
      "type": "string"
    },
    "carrier_variants": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "component_instances": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "constraints": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "figma_metadata_id": {
      "minLength": 1,
      "type": "string"
    },
    "frame_hierarchy": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "layout_id": {
      "minLength": 1,
      "type": "string"
    },
    "non_goals": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "page_arrangement_order": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "derivation_origin": {
            "enum": [
              "PRD_EXPLICIT",
              "DEDUCTIVE_REQUIRED",
              "HUMAN_APPROVED_INFERENCE",
              "REVIEW_REQUIRED_INFERENCE"
            ]
          },
          "figma_frame_order_index": {
            "minimum": 0,
            "type": "integer"
          },
          "frame_id": {
            "minLength": 1,
            "type": "string"
          },
          "function_group_id": {
            "minLength": 1,
            "type": "string"
          },
          "module_id": {
            "minLength": 1,
            "type": "string"
          },
          "page_order_index": {
            "minimum": 0,
            "type": "integer"
          },
          "variant_order_index": {
            "minimum": 0,
            "type": "integer"
          },
          "variant_page_id": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "module_id",
          "function_group_id",
          "variant_page_id",
          "frame_id",
          "page_order_index",
          "variant_order_index",
          "figma_frame_order_index",
          "derivation_origin"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "scroll_frames": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "selection_box_hierarchy": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "state_variants": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "trace_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "z_axis_layers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "figma_metadata_id",
    "layout_id",
    "frame_hierarchy",
    "selection_box_hierarchy",
    "auto_layout_guidance",
    "carrier_variants",
    "scroll_frames",
    "constraints",
    "non_goals",
    "trace_refs",
    "page_arrangement_order"
  ],
  "type": "object"
}
