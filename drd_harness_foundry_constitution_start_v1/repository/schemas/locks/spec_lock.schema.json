{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_by_runtime": {
      "const": "python",
      "type": "string"
    },
    "files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path",
          "sha256"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "lock_id": {
      "minLength": 1,
      "type": "string"
    },
    "phase": {
      "minLength": 1,
      "type": "string"
    },
    "review_decision_hashes": {
      "items": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "root_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "source_lock_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "spec_part_ids": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "validator_identity_hashes": {
      "items": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "validator_results": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "command": {
            "minLength": 1,
            "type": "string"
          },
          "exit_code": {
            "type": "integer"
          },
          "result_hash": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "command",
          "exit_code",
          "result_hash"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "lock_id",
    "phase",
    "spec_part_ids",
    "files",
    "root_sha256",
    "review_decision_hashes",
    "source_lock_refs",
    "validator_results",
    "validator_identity_hashes",
    "created_by_runtime"
  ],
  "type": "object"
}
