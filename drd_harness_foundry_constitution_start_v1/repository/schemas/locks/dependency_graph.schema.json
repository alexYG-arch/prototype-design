{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "edges": {
      "items": {
        "$ref": "dependency_edge.schema.json"
      },
      "minItems": 1,
      "type": "array"
    },
    "graph_id": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "graph_id",
    "edges"
  ],
  "type": "object"
}
